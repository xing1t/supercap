 263:Core/Src/stm32f3xx_it.c ****       static uint16_t boot_mask_cnt = 0;
 264:Core/Src/stm32f3xx_it.c ****     if (boot_mask_cnt < 500) { // 给予 500ms 的启动屏蔽期
 265:Core/Src/stm32f3xx_it.c ****              boot_mask_cnt++;
 266:Core/Src/stm32f3xx_it.c ****         }
 267:Core/Src/stm32f3xx_it.c ****         else{
 268:Core/Src/stm32f3xx_it.c ****    Check_Protection_Fast();
 269:Core/Src/stm32f3xx_it.c ****         }
 270:Core/Src/stm32f3xx_it.c ****  /********************************************************************************************/
 271:Core/Src/stm32f3xx_it.c ****     static uint16_t can_div = 0;
ARM GAS  C:\msys64\tmp\cc89SrRF.s 			page 11


 272:Core/Src/stm32f3xx_it.c **** can_div++;
 273:Core/Src/stm32f3xx_it.c **** 
 274:Core/Src/stm32f3xx_it.c **** if (can_div >= 3600) // 1ms 发送一次
 275:Core/Src/stm32f3xx_it.c **** {
 276:Core/Src/stm32f3xx_it.c ****     can_div = 0;
 277:Core/Src/stm32f3xx_it.c **** 
 278:Core/Src/stm32f3xx_it.c ****         if (HAL_CAN_GetTxMailboxesFreeLevel(&hcan) > 0) 
 279:Core/Src/stm32f3xx_it.c ****     {
 280:Core/Src/stm32f3xx_it.c ****         // 2. 准备数据 (把浮点转成整数，根据你的协议)
 281:Core/Src/stm32f3xx_it.c ****         int16_t send_ia = (int16_t)(g_ctrl.ia * 100.0f);
 282:Core/Src/stm32f3xx_it.c ****         int16_t send_vb = (int16_t)(g_ctrl.vb * 100.0f);
 283:Core/Src/stm32f3xx_it.c ****         
 284:Core/Src/stm32f3xx_it.c ****         TxData[0] = (uint8_t)(send_ia >> 8);
 285:Core/Src/stm32f3xx_it.c ****         TxData[1] = (uint8_t)(send_ia & 0xFF);
 286:Core/Src/stm32f3xx_it.c ****         TxData[2] = (uint8_t)(send_vb >> 8);
 287:Core/Src/stm32f3xx_it.c ****         TxData[3] = (uint8_t)(send_vb & 0xFF);
 288:Core/Src/stm32f3xx_it.c ****         HAL_CAN_AddTxMessage(&hcan, &TxHeader, TxData, &TxMailbox);
 289:Core/Src/stm32f3xx_it.c **** 
 290:Core/Src/stm32f3xx_it.c ****         HAL_GPIO_TogglePin(GPIOB, GPIO_PIN_15); 
 291:Core/Src/stm32f3xx_it.c ****       a++;
 292:Core/Src/stm32f3xx_it.c ****     }
 293:Core/Src/stm32f3xx_it.c **** }
 294:Core/Src/stm32f3xx_it.c **** /**************************************************************************************************
 295:Core/Src/stm32f3xx_it.c ****       static uint8_t  protect_div = 0;
 296:Core/Src/stm32f3xx_it.c ****     protect_div++; 
 297:Core/Src/stm32f3xx_it.c ****     if (protect_div >= 36) //1ms 运行一次慢速保护
 298:Core/Src/stm32f3xx_it.c **** {
 299:Core/Src/stm32f3xx_it.c ****     protect_div = 0;
 300:Core/Src/stm32f3xx_it.c **** 
 301:Core/Src/stm32f3xx_it.c ****    Check_Protection_Slow();
 302:Core/Src/stm32f3xx_it.c **** 
 303:Core/Src/stm32f3xx_it.c ****   }   
 304:Core/Src/stm32f3xx_it.c **** if (g_ctrl.enable == 0) {
 305:Core/Src/stm32f3xx_it.c ****         return; 
 306:Core/Src/stm32f3xx_it.c ****     }
 307:Core/Src/stm32f3xx_it.c **** 
 308:Core/Src/stm32f3xx_it.c ****   Run_Control_Loop();
 309:Core/Src/stm32f3xx_it.c ****     if (g_ctrl.work_mode == MODE_OVER||g_ctrl.enable == 4)
 310:Core/Src/stm32f3xx_it.c **** {
 311:Core/Src/stm32f3xx_it.c ****  HAL_HRTIM_WaveformOutputStop(&hhrtim1, HRTIM_OUTPUT_TA1 | HRTIM_OUTPUT_TA2 | HRTIM_OUTPUT_TB1 | HR
 312:Core/Src/stm32f3xx_it.c ****  return;
 313:Core/Src/stm32f3xx_it.c **** }
 314:Core/Src/stm32f3xx_it.c **** 
 315:Core/Src/stm32f3xx_it.c **** uint16_t period = 16000; // 288kHz 下的周期数
 316:Core/Src/stm32f3xx_it.c ****     uint16_t cmp_buck = (uint16_t)(g_ctrl.final_duty_buck * period);
 317:Core/Src/stm32f3xx_it.c **** if (cmp_buck < 800) cmp_buck = 800; 
 318:Core/Src/stm32f3xx_it.c **** if (g_ctrl.final_duty_buck >= 1.0f) {
 319:Core/Src/stm32f3xx_it.c ****     cmp_buck = period + 1; 
 320:Core/Src/stm32f3xx_it.c **** }
 321:Core/Src/stm32f3xx_it.c **** uint16_t cmp_boost;
 322:Core/Src/stm32f3xx_it.c **** if (g_ctrl.final_duty_boost <= 0.0f) {
 323:Core/Src/stm32f3xx_it.c ****     cmp_boost = period + 1; // 强制关断下管，实现直通
 324:Core/Src/stm32f3xx_it.c **** } else {
 325:Core/Src/stm32f3xx_it.c ****     cmp_boost = (uint16_t)((1.0f - g_ctrl.final_duty_boost) * period);
 326:Core/Src/stm32f3xx_it.c ****     // 限制最大占空比 90% ( 16000 * 0.1 = 1600)
 327:Core/Src/stm32f3xx_it.c ****     if (cmp_boost < 1600) cmp_boost = 1600;    
 328:Core/Src/stm32f3xx_it.c **** }
ARM GAS  C:\msys64\tmp\cc89SrRF.s 			page 12


 329:Core/Src/stm32f3xx_it.c ****     uint16_t adc_trig_point = cmp_buck / 2;
 330:Core/Src/stm32f3xx_it.c ****     // 防止触发点过小导致 ADC 来不及 (虽然 F334 很快，还是留点余量)
 331:Core/Src/stm32f3xx_it.c ****     if (adc_trig_point < 400) adc_trig_point = 400; 
 332:Core/Src/stm32f3xx_it.c **** 
 333:Core/Src/stm32f3xx_it.c ****     // === 寄存器写入 (使用寄存器指针操作以求最快速度) ===
 334:Core/Src/stm32f3xx_it.c ****     
 335:Core/Src/stm32f3xx_it.c ****     // 1. 更新 ADC 触发位置 (CMP2)
 336:Core/Src/stm32f3xx_it.c ****     hhrtim1.Instance->sTimerxRegs[HRTIM_TIMERINDEX_TIMER_A].CMP2xR = adc_trig_point;
 337:Core/Src/stm32f3xx_it.c **** 
 338:Core/Src/stm32f3xx_it.c ****     // 2. 更新 Buck 占空比 (Timer A CMP1)
 339:Core/Src/stm32f3xx_it.c ****     hhrtim1.Instance->sTimerxRegs[HRTIM_TIMERINDEX_TIMER_A].CMP1xR = cmp_buck;
 340:Core/Src/stm32f3xx_it.c ****     
 341:Core/Src/stm32f3xx_it.c ****     // 3. 更新 Boost 占空比 (Timer B CMP1)
 342:Core/Src/stm32f3xx_it.c ****     hhrtim1.Instance->sTimerxRegs[HRTIM_TIMERINDEX_TIMER_B].CMP1xR = cmp_boost;
 343:Core/Src/stm32f3xx_it.c **** }
